{
  "name": "ppt-reel-converter",
  "version": "0.1.0",
  "private": true,
  "description": "Convert landscape PPTX presentations to Instagram Reel (9:16) portrait scenes with AI-assisted layout and per-slide validation gates",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npx tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc && vite build && npx tsc -p tsconfig.electron.json && electron-builder",
    "electron:build:mac": "tsc && vite build && npx tsc -p tsconfig.electron.json && electron-builder --mac",
    "electron:build:win": "tsc && vite build && npx tsc -p tsconfig.electron.json && electron-builder --win",
    "electron:build:linux": "tsc && vite build && npx tsc -p tsconfig.electron.json && electron-builder --linux",
    "electron:build:all": "tsc && vite build && npx tsc -p tsconfig.electron.json && electron-builder --mac --win --linux",
    "lint": "eslint src --ext ts,tsx",
    "typecheck": "tsc --noEmit",
    "py:install": "pip install -r python/requirements.txt",
    "py:profile": "python -m reel_converter.cli profile --template reel_clean",
    "py:convert": "python -m reel_converter.cli convert"
  },
  "build": {
    "appId": "com.than.ppt-reel-converter",
    "productName": "PPT Reel Converter",
    "files": [
      "dist/**/*",
      "python/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "konva": "^9.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  }
}
