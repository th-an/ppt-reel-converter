{
  "name": "ppt-reel-converter",
  "version": "0.1.0",
  "private": true,
  "description": "Convert landscape PPTX presentations to Instagram Reel (9:16) portrait scenes with AI-assisted layout and per-slide validation gates",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "lint": "eslint src --ext ts,tsx",
    "typecheck": "tsc --noEmit",
    "py:install": "pip install -r python/requirements.txt",
    "py:profile": "python -m reel_converter.cli profile --template reel_clean",
    "py:convert": "python -m reel_converter.cli convert"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "konva": "^9.3.0",
    "react-konva": "^18.2.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}